# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# DynamoDB
DYNAMODB_FILES_TABLE=spatial-files-dev

# S3
S3_FILES_BUCKET=spatial-files-dev

# KMS
KMS_KEY_ID=alias/spatial-files-key

# Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxx

# Application
NODE_ENV=development
LOG_LEVEL=debug

# Upload limits
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif,mp4,mov,avi

# Pre-signed URL expiration (seconds)
PRESIGNED_URL_EXPIRATION=3600
